###############################################################################
# .env.example — paperclip-mcp local stack
#
# Copy this file to .env and fill in the required values before starting.
#
#   cp .env.example .env
#   $EDITOR .env
#
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# WARNING: BETTER_AUTH_SECRET IS MANDATORY IN ALL DEPLOYMENT MODES.
# The server calls createBetterAuthInstance() on every startup, regardless of
# PAPERCLIP_DEPLOYMENT_MODE. It throws immediately if this variable is absent.
# Set it even for local_trusted development. Minimum 32 characters.
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
###############################################################################


###############################################################################
# Section 1 — Version Pins
#
# Controls which container images are pulled.
# Update these when upgrading Paperclip. See docs/guides/local-stack.md for
# the upgrade procedure and how to find the correct sha-* tag for a release.
###############################################################################

# Paperclip server image tag. ghcr.io/paperclipai/paperclip uses sha-<commit>
# tags — there are no semver tags in the registry. This tag corresponds to
# GitHub Release v2026.416.0 (2026-04-16). Required.
PAPERCLIP_VERSION=sha-b8725c5

# PostgreSQL image tag. Only used when --profile external-db is active.
# Optional (default embedded PGlite is used when DATABASE_URL is unset).
POSTGRES_VERSION=17.9-alpine

# paperclip-mcp image tag. Used in the .mcp.json MCP client invocation.
# Not a compose service — spawned by Claude Code as a stdio subprocess.
MCP_VERSION=2.1.0


###############################################################################
# Section 2 — Paperclip Server
###############################################################################

# Bind address for the HTTP server. local_trusted mode requires loopback
# (127.0.0.1). With network_mode: host the server is reachable from the host
# at the same address. Use 0.0.0.0 only with PAPERCLIP_DEPLOYMENT_MODE=authenticated.
HOST=127.0.0.1

# TCP port the server listens on. Must match PAPERCLIP_API_URL below. Required.
PORT=3100

# Deployment mode. local_trusted skips per-request authentication — suitable
# for single-user local development only. Use `authenticated` for shared or
# internet-facing deployments. Required.
PAPERCLIP_DEPLOYMENT_MODE=local_trusted

# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# MANDATORY — see the top-of-file warning. Server will NOT start without this.
# For local development any string >= 32 characters is sufficient.
# For production generate a cryptographically random secret:
#   openssl rand -base64 32
# NEVER commit the real value — keep it in .env (gitignored).
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
BETTER_AUTH_SECRET=CHANGE_ME_32_CHARS_MIN_DO_NOT_USE_IN_PRODUCTION

# Serve the React dashboard from the same process as the API. Optional.
SERVE_UI=true

# Disable usage telemetry. Also honoured: DO_NOT_TRACK=1. Optional.
PAPERCLIP_TELEMETRY_DISABLED=1

# Data directory inside the container. /paperclip is pre-owned by the node
# user (UID 1000) in the ghcr.io/paperclipai/paperclip image. Do not change
# this to /root/.paperclip — root's home is mode 700 and inaccessible to
# the node user that the entrypoint drops privileges to. Optional.
# PAPERCLIP_HOME=/paperclip

# PostgreSQL connection string. Leave commented out to use the embedded PGlite
# database (default, no external database required). Uncomment and set this
# value only when running with --profile external-db. Optional.
# DATABASE_URL=postgres://paperclip:CHANGE_ME@localhost:5432/paperclip

# PostgreSQL credentials — only used with --profile external-db. Optional.
# POSTGRES_USER=paperclip
# POSTGRES_PASSWORD=CHANGE_ME
# POSTGRES_DB=paperclip

# Master key for encrypting secrets stored in the database. Auto-generated on
# first run if absent (stored inside the paperclip-data volume). Provide an
# explicit value if you need deterministic key material across container
# restarts or when restoring from backup. Optional.
# PAPERCLIP_SECRETS_MASTER_KEY=

# Reject plaintext *_API_KEY / *_TOKEN environment variables (force encrypted
# secret store only). Default false — leave unset for local development. Optional.
# PAPERCLIP_SECRETS_STRICT_MODE=false

# Enable the Claude Local adapter (requires Anthropic API access). Optional.
# ANTHROPIC_API_KEY=sk-ant-...

# Enable the Codex Local adapter (requires OpenAI API access). Optional.
# OPENAI_API_KEY=sk-...


###############################################################################
# Section 3 — paperclip-mcp (MCP client environment)
#
# These variables are NOT used by the compose stack directly. They are passed
# to the paperclip-mcp subprocess by Claude Code's MCP client (see .mcp.json
# and docs/guides/local-stack.md for the invocation pattern).
###############################################################################

# Bearer token for paperclip-mcp -> Paperclip API authentication.
# Obtain from the Paperclip UI under Settings -> API Keys. Required.
PAPERCLIP_API_KEY=

# Base URL of the running Paperclip server. Must match HOST + PORT above.
# Do not add a trailing slash. Required.
PAPERCLIP_API_URL=http://127.0.0.1:3100

# UUID of the agent that paperclip-mcp will act as. Obtain from the Paperclip
# UI under Agents. Required.
PAPERCLIP_AGENT_ID=

# UUID of your Paperclip company/tenant. Obtain from the Paperclip UI under
# Settings -> Company. Required.
PAPERCLIP_COMPANY_ID=

# Execution run ID for mutation tracing. Injected automatically by the
# Paperclip server at heartbeat time — leave blank for manual invocations. Optional.
# PAPERCLIP_RUN_ID=
