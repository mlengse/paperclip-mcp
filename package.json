{
  "name": "paperclip-mcp",
  "version": "2.1.0",
  "description": "Paperclip MCP server for Claude Code agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "paperclip-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "Bruno S. Brasil",
  "keywords": [
    "mcp",
    "paperclip",
    "claude",
    "model-context-protocol"
  ],
  "mcpName": "paperclip",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bruhsb/paperclip-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/bruhsb/paperclip-mcp/issues"
  },
  "homepage": "https://github.com/bruhsb/paperclip-mcp#readme",
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build && node scripts/setup-husky.mjs",
    "check:no-raw-inputschema": "node scripts/check-no-raw-inputschema.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint --cache --cache-location .eslintcache --cache-strategy content src",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test 'src/**/*.test.ts'",
    "test:coverage": "node --import tsx/esm --experimental-test-coverage --test-coverage-lines=80 --test-coverage-branches=70 --test 'src/**/*.test.ts'",
    "docs:check": "find docs -name '*.md' | xargs markdown-link-check -c .markdown-link-check.json",
    "docs:generate": "tsx scripts/generate-tool-docs.ts && prettier --log-level=warn --write docs/tools/",
    "test:functional": "node --import tsx/esm scripts/functional-test.mjs",
    "docker:build": "podman build -t paperclip-mcp:2.0.0 -t paperclip-mcp:latest .",
    "docker:smoke": "node scripts/smoke-docker.mjs",
    "test:functional:docker": "node --import tsx/esm scripts/functional-test-docker.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdown-link-check": "^3.12.0",
    "prettier": "^3.0.0",
    "semantic-release": "^25.0.3",
    "shx": "^0.3.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md}": [
      "prettier --write"
    ]
  }
}
